[Metadata]
Name[zh_CN]=$BACKGROUND_COLOR_NAME_ZH$微风（$ACCENT_COLOR_NAME_ZH$，透明）
Name=Breeze $BACKGROUND_COLOR_NAME$ translucent $ACCENT_COLOR_NAME$
Version=1
Author=Scratcher & Shining Yang
Description=Fcitx5 theme matching KDE's breeze style, $BACKGROUND_COLOR_NAME$ varient, with blur effect.
Description[zh_CN]=与KDE微风主题相配套的Fcitx5主题，$BACKGROUND_COLOR_NAME_ZH$版本，带透明特效。
ScaleWithDPI=True

[InputPanel]
LabelTextSizeFactor=75
CommentTextSizeFactor=75
EnableBlur=True
NormalColor=$NORMAL_COLOR$
HighlightColor=$HIGHLIGHT_COLOR$
HighlightCandidateColor=$NORMAL_COLOR$
Spacing=3
PageButtonAlignment="Last Candidate"

[InputPanel/CandidateLabelColor]
Value=$ACCENT_COLOR$

[InputPanel/HighlightCandidateLabelColor]
Value=$ACCENT_COLOR$

[InputPanel/CandidateCommentColor]
Value=$ACCENT_COLOR$aa

[InputPanel/HighlightCandidateCommentColor]
Value=$ACCENT_COLOR$aa

[InputPanel/BlurMargin]
Left=1
Right=1
Top=1
Bottom=1

[InputPanel/TextMargin]
Left=6
Right=6
Top=6
Bottom=6

[InputPanel/ContentMargin]
Left=8
Right=8
Top=8
Bottom=8

