[Metadata]
Name[zh_CN]=$BACKGROUND_COLOR_NAME_ZH$微风（$ACCENT_COLOR_NAME_ZH$）
Name=Breeze $BACKGROUND_COLOR_NAME$ $ACCENT_COLOR_NAME$
Version=1
Author=Scratcher & Shining Yang
Description=Fcitx5 theme matching KDE's breeze style, $BACKGROUND_COLOR_NAME$ varient.
Description[zh_CN]=与KDE微风主题相配套的Fcitx5主题，$BACKGROUND_COLOR_NAME_ZH$版本。
ScaleWithDPI=True

[InputPanel]
LabelTextSizeFactor=75
CommentTextSizeFactor=75
EnableBlur=False
NormalColor=$NORMAL_COLOR$
HighlightColor=$HIGHLIGHT_COLOR$
HighlightCandidateColor=$NORMAL_COLOR$
Spacing=3
PageButtonAlignment="Last Candidate"

[InputPanel/CandidateLabelColor]
Value=$ACCENT_COLOR$

[InputPanel/HighlightCandidateLabelColor]
Value=$ACCENT_COLOR$

[InputPanel/CandidateCommentColor]
Value=$ACCENT_COLOR$aa

[InputPanel/HighlightCandidateCommentColor]
Value=$ACCENT_COLOR$aa

[InputPanel/TextMargin]
Left=6
Right=6
Top=6
Bottom=6

[InputPanel/ContentMargin]
Left=6
Right=6
Top=6
Bottom=6

